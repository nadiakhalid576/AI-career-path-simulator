# Career Path Backend Environment Variables
# Copy this file to .env and fill in real values

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True

# ─── Primary LLM: Google Gemini ─────────────────────────────────────────────
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model. Default = gemini-2.5-flash (has free-tier access for new keys).
# Try gemini-flash-latest or gemini-1.5-flash if you hit "limit: 0" 429 errors,
# which means the chosen model has no free-tier quota for your project.
# GEMINI_MODEL=gemini-2.5-flash

# ─── Fallback LLM: xAI Grok ─────────────────────────────────────────────────
# Get a key from https://console.x.ai/. If Gemini is rate-limited or down,
# the service automatically falls back to Grok before giving up to mock data.
# Either env name is accepted (XAI_API_KEY is the official name, GROK_API_KEY
# is provided as a more recognisable alias).
XAI_API_KEY=
# GROK_API_KEY=

# Grok model. Default = grok-4-fast. Other options: grok-4, grok-3-mini.
# GROK_MODEL=grok-4-fast

# Grok endpoint — leave default unless you're using a proxy / Azure mirror.
# GROK_BASE_URL=https://api.x.ai/v1

# ─── Shared HTTP timeout ────────────────────────────────────────────────────
# How long (seconds) to wait for ANY single LLM call before giving up. Lower
# this if you see WinError 10060 / network timeouts, higher if you have a slow
# link. Applies to both Gemini and Grok.
# GEMINI_HTTP_TIMEOUT=10
